package cleaning_robots

import io.sarl.api.core.Logging
import io.sarl.api.core.Behaviors
import io.sarl.api.core.Initialize

enum State{
	SWEEPING, PICKING, DELIVERING, RETURNING
}

agent CleanerAgent{
	uses Logging, Behaviors, Cleaning
	
	var ag: String
	var agX: int
	var agY: int
	var state: State
	var lastX: int
	var lastY: int
	
	var r2X: int
	var r2Y: int
	
	on Initialize{
		ag = occurrence.parameters.get(0) as String
		r2X = GridConfig::R2X
		r2Y = GridConfig::R2Y
		state = State::SWEEPING
		setSkill(new CleaningSkill)
		nextSlot(ag)
	}
	
	on PerceptEvent{
		if(occurrence.ag == ag){
			agX = occurrence.x
			agY = occurrence.y
			
			switch(state){
				case SWEEPING: {
					if(occurrence.hasGarbage){
						lastX = agX
						lastY = agY
						state = State::PICKING
						pickUp(ag)
					}
					else{
						nextSlot(ag)
					}
				}
				case PICKING: {
					if(occurrence.hasGarbage){
						pickUp(ag)
					}
					else{
						state = State::DELIVERING
						moveTowards(ag, r2X, r2Y)
					}
				}
				case DELIVERING: {
					if(agX==r2X && agY==r2Y){
						drop(ag)
						state = State::RETURNING
					}
					else{
						moveTowards(ag, r2X, r2Y)
					}
				}
				case RETURNING: {
					if(agX==lastX && agY==lastY){
						state = State::SWEEPING
						nextSlot(ag)
					}
					else{
						moveTowards(ag, lastX, lastY)
					}
				}
			}
		}
	}
	
}